APP_MODE=demo
APP_NAME=Kavach Saathi Agents
API_PREFIX=/v1
FRONTEND_ORIGIN=http://localhost:3000
DATA_DIR=data/seed
ASSET_DIR=assets/mock
MEDIA_STORAGE_BACKEND=auto
MEDIA_ENDPOINT_URL=
MEDIA_ACCESS_KEY_ID=
MEDIA_SECRET_ACCESS_KEY=
MEDIA_PUBLIC_BASE_URL=
MEDIA_LOCAL_READ_FALLBACK=true
MEDIA_PRESIGN_EXPIRY_SECONDS=900
CATALOGUE_POSTGRES_SEARCH_ENABLED=true
CATALOGUE_FUZZY_SEARCH_THRESHOLD=0.6
CATALOGUE_SEARCH_CANDIDATE_LIMIT=1000

# Postgres (docker-compose default; database-per-service is documented as a deviation, see docs/ARCHITECTURE.md)
DATABASE_URL=postgresql+psycopg://kavach:kavach@localhost:5432/kavach_saathi
DATABASE_READ_URL=
DATABASE_SSL_MODE=
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_STATEMENT_TIMEOUT_MS=0
DATABASE_APPLICATION_NAME=kavach-saathi
DATABASE_READ_POOL_SIZE=5
REQUIRE_READ_DATABASE_READY=false

# Redis (cache + Redis Streams event bus + Nano Banana 2 quota tracking)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=
REDIS_STREAM_URL=
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT_SECONDS=5
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_RETRY_ON_TIMEOUT=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RUN_EVENT_CONSUMERS_IN_WEB=true
RUN_WORKFLOWS_IN_WEB=true
DEPLOYMENT_ENVIRONMENT=local
RELEASE_VERSION=development
REQUIRE_WORKER_READY=false
WORKER_HEARTBEAT_TTL_SECONDS=15

# Auth (JWT)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

# Groq reasoning -- real-time fallback when Gemini's shared capacity returns a 503;
# GROQ_VISION_MODEL is used instead of GROQ_MODEL for image-bearing calls (OCR/vision
# extraction), since Groq's text models can't read images.
GROQ_API_KEY=
EXTERNAL_SECRET_ARN=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_REASONING_EFFORT=medium
REASONING_MODE=demo

# Anthropic Claude (Agent 2 OCR/vision extraction, Agent 3/5/7 reasoning)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini — one key covers everything below: image generation ("Nano Banana 2",
# Agent 1) AND text/vision reasoning (Agents 2/3/5/7, substituting for the plan's named
# Claude since Anthropic has no free tier -- see project notes). "Nano Banana 2" isn't
# an official model ID, just a nickname, so the exact image model may need adjusting;
# nano-banana-pro-preview is also worth trying if flash-image underperforms.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_REASONING_MODEL=gemini-3.5-flash
NANO_BANANA_DAILY_QUOTA=15

# Pinecone (Agent 3 cross-seller size RAG, Agent 5 grounding + learning loop)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# Razorpay sandbox (checkout payment step)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# DigiLocker (seller KYC OAuth2)
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# Google Maps Geocoding (Agent 6 address resolution)
GOOGLE_MAPS_API_KEY=

# AWS
AWS_REGION=ap-south-1
WORKFLOW_TABLE=kavach-saathi-workflows
DOMAIN_TABLE=kavach-saathi-domain
MEDIA_BUCKET=kavach-saathi-media
NOVA_MODEL_ID=amazon.nova-2-lite-v1:0
NOVA_CANVAS_MODEL_ID=amazon.nova-canvas-v1:0
MODEL_TEMPLATE_KEYS=templates/model-front.png,templates/model-back.png,templates/model-left.png,templates/model-right.png
STATE_MACHINE_ARN=

# Bhashini (kept for reference; requires an institutional SPOC for API access, which
# blocks an individual build -- Sarvam AI below is the self-serve substitute in use)
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=
BHASHINI_CONFIG_URL=https://meity-auth.ulcacontrib.org/ulca/apis/v0/model/getModelsPipeline

# Sarvam AI -- real ASR/TTS for Agent 5 (voice Q&A) and Agent 7 (verification call)
SARVAM_API_KEY=

# Google Vision Web Detection (Agent 1 stolen-photo check) -- plain REST API key,
# same project as GOOGLE_MAPS_API_KEY works once Cloud Vision API is enabled on it.
GOOGLE_VISION_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Twilio -- Agent 7's real outbound verification call + WhatsApp fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_VERIFY_SERVICE_SID=
TWILIO_ORDER_CONFIRMATION_CONTENT_SID=
TWILIO_DELIVERY_DATE_CONTENT_SID=
TWILIO_RESCHEDULE_CONTENT_SID=
TWILIO_CANCELLATION_CONTENT_SID=
AGENT7_MAX_RETRIES=2

# Address phone verification. OTP_DEMO_CODE is honored only when APP_MODE=demo;
# leave it blank to send real SMS through the Twilio credentials above.
OTP_DEMO_CODE=
ALLOW_DEMO_OTP=false
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=3

# Email-OTP channel -- a free alternative to Twilio WhatsApp OTP (which on a
# trial account only delivers to one verified phone number) for
# signup/order-confirm/delivery/return. Works with Gmail SMTP: use your Gmail
# address as SMTP_USERNAME and a 16-character Google "App Password" (Account ->
# Security -> 2-Step Verification -> App Passwords) as SMTP_PASSWORD -- not your
# regular Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Kavach Saathi

# Publicly reachable URL for this backend (e.g. an ngrok tunnel) -- required for
# Twilio's voice webhooks; Twilio's servers cannot reach localhost.
PUBLIC_BASE_URL=
