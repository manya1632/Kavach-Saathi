APP_MODE=demo
APP_NAME=Kavach Saathi Agents
API_PREFIX=/v1
FRONTEND_ORIGIN=http://localhost:3000
DATA_DIR=data/seed
ASSET_DIR=assets/mock

# Postgres (docker-compose default; database-per-service is documented as a deviation, see docs/ARCHITECTURE.md)
DATABASE_URL=postgresql+psycopg://kavach:kavach@localhost:5432/kavach_saathi

# Redis (cache + Redis Streams event bus + Nano Banana 2 quota tracking)
REDIS_URL=redis://localhost:6379/0

# Auth (JWT)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

# Groq reasoning (being phased out in favour of Claude per the plan; still used until Agent 5's rewrite)
GROQ_API_KEY=
EXTERNAL_SECRET_ARN=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_REASONING_EFFORT=medium
REASONING_MODE=demo

# Anthropic Claude (Agent 2 OCR/vision extraction, Agent 3/5/7 reasoning)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini — one key covers everything below: image generation ("Nano Banana 2",
# Agent 1) AND text/vision reasoning (Agents 2/3/5/7, substituting for the plan's named
# Claude since Anthropic has no free tier -- see project notes). "Nano Banana 2" isn't
# an official model ID, just a nickname, so the exact image model may need adjusting;
# nano-banana-pro-preview is also worth trying if flash-image underperforms.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_REASONING_MODEL=gemini-3.5-flash
NANO_BANANA_DAILY_QUOTA=15

# Pinecone (Agent 3 cross-seller size RAG, Agent 5 grounding + learning loop)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# Razorpay sandbox (checkout payment step)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# DigiLocker (seller KYC OAuth2)
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# Google Maps Geocoding (Agent 6 address resolution)
GOOGLE_MAPS_API_KEY=

# AWS
AWS_REGION=ap-south-1
WORKFLOW_TABLE=kavach-saathi-workflows
DOMAIN_TABLE=kavach-saathi-domain
MEDIA_BUCKET=kavach-saathi-media
NOVA_MODEL_ID=amazon.nova-2-lite-v1:0
NOVA_CANVAS_MODEL_ID=amazon.nova-canvas-v1:0
MODEL_TEMPLATE_KEYS=templates/model-front.png,templates/model-back.png,templates/model-left.png,templates/model-right.png
STATE_MACHINE_ARN=

# Bhashini (kept for reference; requires an institutional SPOC for API access, which
# blocks an individual build -- Sarvam AI below is the self-serve substitute in use)
BHASHINI_USER_ID=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=
BHASHINI_CONFIG_URL=https://meity-auth.ulcacontrib.org/ulca/apis/v0/model/getModelsPipeline

# Sarvam AI -- real ASR/TTS for Agent 5 (voice Q&A) and Agent 7 (verification call)
SARVAM_API_KEY=

# Google Vision Web Detection
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Twilio -- Agent 7's real outbound verification call + WhatsApp fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
AGENT7_MAX_RETRIES=2

# Publicly reachable URL for this backend (e.g. an ngrok tunnel) -- required for
# Twilio's voice webhooks; Twilio's servers cannot reach localhost.
PUBLIC_BASE_URL=
